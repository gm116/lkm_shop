# Backend (Django) env example

# ------------------------------
# Безопасность / режим
# ------------------------------
SECRET_KEY=change-me-to-long-random-value
DEBUG=false

# ------------------------------
# Сетевые настройки backend
# ------------------------------
ALLOWED_HOSTS=127.0.0.1,localhost,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEV_NGROK_URL=

# ------------------------------
# База данных
# Для IDE/локального запуска:
# DB_HOST=localhost
# DB_PORT=5544
#
# Для docker-compose backend DB_HOST/DB_PORT переопределяются в compose
# (db:5432), здесь можно оставить локальные значения.
# ------------------------------
DB_NAME=shop
DB_USER=shop
DB_PASSWORD=shop
DB_HOST=localhost
DB_PORT=5544

# ------------------------------
# Платежи YooKassa
# ------------------------------
YOOKASSA_ACCOUNT_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/checkout/success
YOOKASSA_WEBHOOK_ALLOWED_IPS=
YOOKASSA_WEBHOOK_TRUST_X_FORWARDED_FOR=false
YOOKASSA_WEBHOOK_ENFORCE_IP_WHITELIST=true

# ------------------------------
# Почта
# ------------------------------
DEFAULT_FROM_EMAIL=no-reply@example.com
FEEDBACK_TO_EMAIL=info@example.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10

# ------------------------------
# Auth / сроки
# ------------------------------
FRONTEND_URL=http://localhost:3000
PASSWORD_RESET_TIMEOUT=3600
EMAIL_VERIFICATION_CODE_TTL=600
EMAIL_VERIFICATION_RESEND_COOLDOWN=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_PENDING_RETENTION=86400
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_PATH=/
